doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    title SerialForge - ナンバーを発行
    style.

      body, html {
        height: 100%;
        margin: 0;
      }

      .center-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
      }

      .form-container {
        width: 100%;
        max-width: 400px;
        padding: 20px;
        box-sizing: border-box;
      }

      #result-area {
        min-height: 60px;
        margin-top: 15px;
      }

  body
    .center-wrapper
      .form-container
        h2.mb-4.text-center
          strong ナンバーを発行
        form#make-form
          .form-floating.mb-3
            input#count.form-control(type="number" name="count" placeholder=" ")
            label(for="count") 回数

          .form-floating.mb-3
            - const today = new Date().toISOString().split('T')[0];
            input#expiry.form-control(type="date" name="expiry" min=today placeholder=" ")
            label(for="expiry") 有効期限

          .form-floating.mb-3
            input#password.form-control(type="password" name="password" placeholder=" ")
            label(for="password") パスワード

          .d-grid
            button.btn.btn-primary(type="submit") 発行する

        #result-area

    script.
      const form = document.getElementById('make-form');
      const resultArea = document.getElementById('result-area');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);

        const res = await fetch('/make', { method: 'POST', body: formData });
        const data = await res.json();

        if (data.success) {
          resultArea.innerHTML = `
            <div class="alert alert-success" role="alert">
              シリアルナンバー：${data.serialNumber.match(/.{1,4}/g).join('-')}
            </div>
          `;
        } else {
          resultArea.innerHTML = `
            <div class="alert alert-danger" role="alert">
              ${data.message}
            </div>
          `;
        }
      });