doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    title SerialForge - ナンバーを発行
  body.d-flex.justify-content-center.align-items-center.vh-100
    .container
      .row.justify-content-center
        .col-12.col-sm-8.col-md-6.col-lg-4

          h2.mb-4
            strong ナンバーを発行

          form#login-form

            .form-floating.mb-3
              input#count.form-control(type="number" placeholder=" ")
              label(for="count") 回数

            .form-floating.mb-3
              - const today = new Date().toISOString().split('T')[0];
              input#expiry.form-control(
                type="date" 
                placeholder=" " 
                min=today
              )
              label(for="expiry") 有効期限

            .form-floating.mb-3
              input#password.form-control(type="password" placeholder=" ")
              label(for="password") パスワード

            .d-grid
              button.btn.btn-primary(type="submit") 発行する