doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    title SerialForge - ナンバーを利用
    style.
      body, html {
        height: 100%;
        margin: 0;
      }

      .center-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100%;
      }

      .form-container {
        width: 100%;
        max-width: 400px;
        padding: 20px;
        box-sizing: border-box;
      }

      #result-area {
        min-height: 60px; /* アラートがなくてもスペース確保 */
        margin-top: 15px;
      }

  body
    .center-wrapper
      .form-container
        h2.mb-4.text-center
          strong ナンバーを利用
        form#use-form
          .form-floating.mb-3
            input#serialNumber.form-control(type="text" name="serialNumber" placeholder=" ")
            label(for="serialNumber") シリアルナンバー

          .form-floating.mb-3
            input#password.form-control(type="password" name="password" placeholder=" ")
            label(for="password") パスワード

          .d-grid
            button.btn.btn-primary(type="submit") 利用する

        #result-area

    script.
      const form = document.getElementById('use-form');
      const resultArea = document.getElementById('result-area');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);

        const res = await fetch('/use', { method: 'POST', body: formData });
        const data = await res.json();

        if (data.success) {
          resultArea.innerHTML = `
            <div class="alert alert-success" role="alert">
              ${data.message}
            </div>
          `;
        } else {
          resultArea.innerHTML = `
            <div class="alert alert-danger" role="alert">
              ${data.message}
            </div>
          `;
        }
      });