doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet")
    title SerialForge - シリアルナンバーを発行
  style
    body {
      font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Google Sans"
    }
  body(class="d-flex justify-content-center align-items-center vh-100 position-relative")
    div(class="text-center")
      h1: strong SerialForge
      p シリアルナンバーを発行・利用できるサービスです
      div(class="d-grid gap-2 mx-auto" style="max-width: 300px;")
        button(class="btn btn-primary" type="button" onclick="location.href='/make'") 発行する
        button(class="btn btn-primary" type="button" onclick="location.href='/use'") 利用する
  
    p(class="position-absolute bottom-0 start-50 translate-middle-x small text-muted mb-2")
      | Product by 
      em
        a(href="https://x.com/namiyama_814" target="_blank" rel="noopener noreferrer") namiyama
